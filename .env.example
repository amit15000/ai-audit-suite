# Project W - Environment Variables
# Copy this file to .env and update with your actual values

# ============================================================================
# Application Settings
# ============================================================================
# Environment: local, dev, or prod
ENVIRONMENT=local

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# Database Configuration (DB_ prefix)
# ============================================================================
# Database connection URL
# SQLite (local): sqlite:///var/audit.db
# PostgreSQL: postgresql://user:password@localhost:5432/audit_db
# PostgreSQL with pgvector: postgresql://user:password@localhost:5432/audit_db
# DB_URL=sqlite:///var/audit.db

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# ============================================================================
# Storage Configuration (STORAGE_ prefix)
# ============================================================================
# S3-compatible endpoint URL
# Local MinIO: http://localhost:9000
# AWS S3: https://s3.amazonaws.com
# Other S3-compatible: https://your-s3-endpoint.com
STORAGE_S3_ENDPOINT=http://localhost:9000

# S3 bucket name
STORAGE_S3_BUCKET=w-audit

# Local filesystem root (used when S3 is not configured)
STORAGE_LOCAL_ROOT=var/object_store
DATABASE_PASSWORD= ke0Zha74KEw84EYX
# S3 Credentials (for production S3-compatible storage)
STORAGE_S3_ACCESS_KEY_ID=minioadmin
STORAGE_S3_SECRET_ACCESS_KEY=minioadmin
# STORAGE_S3_REGION=us-east-1

# ============================================================================
# Embedding Model Configuration (EMBED_ prefix)
# ============================================================================
# Embedding model name (e.g., text-embedding-3-large, text-embedding-ada-002)
EMBED_MODEL_NAME=text-embedding-3-large

# Embedding API Key (if required by the provider)
# EMBED_API_KEY=your-embedding-api-key

# ============================================================================
# Adapter Configuration (ADAPTER_ prefix)
# ============================================================================
# Adapter provider: mock, openai, anthropic, etc.
ADAPTER_PROVIDER=openai

# Request timeout in seconds
ADAPTER_TIMEOUT_SECONDS=30

# Maximum retry attempts
ADAPTER_MAX_RETRIES=2

# LLM Provider API Keys (uncomment and set as needed)
OPENAI_API_KEY=

# ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=


# New free platforms
GROQ_API_KEY=
TOGETHER_API_KEY=
HUGGINGFACE_API_KEY=
  # Optional for public models
# ============================================================================
# Optional: Redis Configuration (if using Redis)
# ============================================================================
# REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=

# ============================================================================
# Optional: Security & Authentication
# ============================================================================
# API_KEY=your-api-key-for-authentication
# SECRET_KEY=your-secret-key-for-signing
JWT_SECRET_KEY=


# Google Custom Search API (for factual accuracy checking)
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=